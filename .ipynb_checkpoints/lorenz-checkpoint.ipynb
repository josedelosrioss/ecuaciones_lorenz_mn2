    "import plotly.graph_objects as go\n",
    "from ipywidgets import FloatLogSlider, interact\n",
    "\n",
    "\n",
    "def dibujar_lorenz_rho(rho_val):\n",
    "    t_rho, sol_rho = rk4(lorenz, y0, 0, 100, h, sigma, rho_val, beta)\n",
    "    x_rho, y_rho, z_rho = sol_rho[:, 0], sol_rho[:, 1], sol_rho[:, 2]\n",
    "\n",
    "    fig = go.Figure()\n",
    "    fig.add_trace(go.Scatter3d(\n",
    "        x=x_rho,\n",
    "        y=y_rho,\n",
    "        z=z_rho,\n",
    "        mode='lines',\n",
    "        line=dict(width=2, color=z_rho, colorscale='Viridis'),\n",
    "    ))\n",
    "\n",
    "    fig.update_layout(\n",
    "        title=f'Atractor de Lorenz para rho = {rho_val:.2f}',\n",
    "        scene=dict(\n",
    "            xaxis_title='x',\n",
    "            yaxis_title='y',\n",
    "            zaxis_title='z',\n",
    "        ),\n",
    "        width=850,\n",
    "        height=700,\n",
    "        margin=dict(l=0, r=0, b=0, t=40),\n",
    "    )\n",
    "\n",
    "    fig.show()\n",
    "\n",
    "\n",
    "interact(\n",
    "    dibujar_lorenz_rho,\n",
    "    rho_val=FloatLogSlider(\n",
    "        value=28,\n",
    "        base=10,\n",
    "        min=-2,\n",
    "        max=2,\n",
    "        step=0.01,\n",
    "        description='rho',\n",
    "        continuous_update=False,\n",
    "        readout_format='.2f',\n",
    "    ),\n",
    ");"
   ]
  },
